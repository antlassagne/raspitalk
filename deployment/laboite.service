[Unit]
Description=Laboite - Interactive Story Box
After=network.target sound.target

[Service]
Type=simple
WorkingDirectory=/usr/local/raspitalk
Environment="PYTHONUNBUFFERED=1"
Environment="GPIOZERO_PIN_FACTORY=lgpio"
ExecStart=/usr/local/raspitalk/.venv/bin/python3 main.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
